#!/usr/bin/env python3
"""
WorldMonitor CLI - 命令行控制工具
"""

import argparse
import asyncio
import json
import sys
import time
from pathlib import Path
from typing import Any, Dict

# 添加模块路径
import os
sys.path.insert(0, str(Path(__file__).parent / 'worldmonitor'))

from world_monitor import WorldMonitor
from event_bus import Event, EventPriority, publish_event

logger = logging.getLogger(__name__)


class Colors:
    """终端颜色"""
    HEADER = '\033[95m'
    OKBLUE = '\033[94m'
    OKCYAN = '\033[96m'
    OKGREEN = '\033[92m'
    WARNING = '\033[93m'
    FAIL = '\033[91m'
    ENDC = '\033[0m'
    BOLD = '\033[1m'
    UNDERLINE = '\033[4m'


def print_success(msg: str):
    print(f"{Colors.OKGREEN}✓ {msg}{Colors.ENDC}")


def print_error(msg: str):
    print(f"{Colors.FAIL}✗ {msg}{Colors.ENDC}")


def print_info(msg: str):
    print(f"{Colors.OKCYAN}ℹ {msg}{Colors.ENDC}")


def print_warning(msg: str):
    print(f"{Colors.WARNING}⚠ {msg}{Colors.ENDC}")


class WorldMonitorCLI:
    """CLI 工具类"""
    
    def __init__(self):
        self.config_path = Path("~/.hermes/config/worldmonitor.yaml").expanduser()
    
    async def start(self, daemon: bool = False, foreground: bool = True):
        """启动服务"""
        if self._is_running():
            print_error("WorldMonitor is already running")
            return 1
        
        print_info("Starting WorldMonitor...")
        
        monitor = WorldMonitor(self.config_path)
        
        if daemon and not foreground:
            # 后台运行（使用子进程）
            import subprocess
            script_path = Path(__file__).parent / 'world_monitor.py'
            subprocess.Popen(
                [sys.executable, str(script_path)],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                start_new_session=True
            )
            time.sleep(2)  # 等待启动
            
            if self._is_running():
                print_success("WorldMonitor started in background")
                return 0
            else:
                print_error("Failed to start")
                return 1
        else:
            # 前台运行
            try:
                await monitor.start()
            except KeyboardInterrupt:
                print_info("\nInterrupted")
            except Exception as e:
                print_error(f"Failed to start: {e}")
                return 1
            finally:
                await monitor.stop()
            
            return 0
    
    async def stop(self):
        """停止服务"""
        if not self._is_running():
            print_warning("WorldMonitor is not running")
            return 0
        
        print_info("Stopping WorldMonitor...")
        
        # 发送停止信号
        pid = self._get_pid()
        if pid:
            try:
                import signal
                os.kill(pid, signal.SIGTERM)
                time.sleep(2)
                
                if self._is_running():
                    print_error("Failed to stop gracefully, trying SIGKILL")
                    os.kill(pid, signal.SIGKILL)
                
                print_success("WorldMonitor stopped")
                return 0
            except Exception as e:
                print_error(f"Failed to stop: {e}")
                return 1
        
        return 1
    
    async def status(self):
        """查看状态"""
        try:
            async with aiohttp.ClientSession() as session:
                async with session.get('http://localhost:11000/monitor_status') as resp:
                    if resp.status == 200:
                        status = await resp.json()
                        self._print_status(status)
                        return 0
                    else:
                        print_error(f"Service returned status {resp.status}")
                        return 1
        except aiohttp.ClientError:
            print_error("WorldMonitor is not running")
            return 1
    
    async def reload(self):
        """热重载配置"""
        try:
            async with aiohttp.ClientSession() as session:
                async with session.post('http://localhost:11000/monitor_reload') as resp:
                    if resp.status == 200:
                        result = await resp.json()
                        print_success(result.get('message', 'Configuration reloaded'))
                        return 0
                    else:
                        error = await resp.text()
                        print_error(f"Reload failed: {error}")
                        return 1
        except aiohttp.ClientError:
            print_error("WorldMonitor is not running")
            return 1
    
    async def list_sources(self):
        """列出事件源"""
        try:
            async with aiohttp.ClientSession() as session:
                async with session.get('http://localhost:11000/monitor_sources') as resp:
                    if resp.status == 200:
                        data = await resp.json()
                        self._print_sources(data.get('sources', []))
                        return 0
                    else:
                        print_error(f"Failed to fetch sources: {resp.status}")
                        return 1
        except aiohttp.ClientError:
            print_error("WorldMonitor is not running")
            return 1
    
    async def list_events(self, limit: int = 20, source: str = None, event_type: str = None):
        """列出事件"""
        params = {'limit': limit}
        if source:
            params['source'] = source
        if event_type:
            params['type'] = event_type
        
        try:
            async with aiohttp.ClientSession() as session:
                async with session.get('http://localhost:11000/monitor_events', params=params) as resp:
                    if resp.status == 200:
                        data = await resp.json()
                        self._print_events(data.get('events', []), data.get('total', 0))
                        return 0
                    else:
                        print_error(f"Failed to fetch events: {resp.status}")
                        return 1
        except aiohttp.ClientError:
            print_error("WorldMonitor is not running")
            return 1
    
    async def send_test_event(self, event_type: str = 'test', data: str = '{}'):
        """发送测试事件"""
        try:
            event_data = json.loads(data)
        except json.JSONDecodeError:
            print_error("Invalid JSON data")
            return 1
        
        try:
            async with aiohttp.ClientSession() as session:
                payload = {
                    'source': 'cli',
                    'type': event_type,
                    'data': event_data,
                    'priority': 5,
                    'tags': ['test']
                }
                async with session.post('http://localhost:11000/webhook/worldmonitor', json=payload) as resp:
                    if resp.status == 200:
                        print_success("Test event sent")
                        return 0
                    else:
                        print_error(f"Failed to send: {resp.status}")
                        return 1
        except aiohttp.ClientError:
            print_error("WorldMonitor is not running")
            return 1
    
    async def toggle_source(self, source_id: str):
        """启用/禁用事件源"""
        try:
            async with aiohttp.ClientSession() as session:
                async with session.post(f'http://localhost:11000/monitor_sources/{source_id}/toggle') as resp:
                    if resp.status == 200:
                        result = await resp.json()
                        status = 'enabled' if result.get('enabled') else 'disabled'
                        print_success(f"Source {source_id} {status}")
                        return 0
                    else:
                        error = await resp.text()
                        print_error(f"Failed to toggle: {error}")
                        return 1
        except aiohttp.ClientError:
            print_error("WorldMonitor is not running")
            return 1
    
    def _is_running(self) -> bool:
        """检查服务是否运行"""
        pid = self._get_pid()
        if pid:
            try:
                os.kill(pid, 0)
                return True
            except OSError:
                pass
        return False
    
    def _get_pid(self) -> int:
        """获取 PID"""
        pid_file = Path("~/.hermon/worldmonitor.pid").expanduser()
        if pid_file.exists():
            try:
                return int(pid_file.read_text().strip())
            except:
                pass
        return 0
    
    def _print_status(self, status: Dict):
        """打印状态"""
        print(f"\n{Colors.BOLD}WorldMonitor Status{Colors.ENDC}")
        print(f"  Running: {Colors.OKGREEN if status['running'] else Colors.FAIL}{status['running']}{Colors.ENDC}")
        print(f"  Health: {Colors.OKGREEN if status['health']['healthy'] else Colors.FAIL}{status['health']['healthy']}{Colors.ENDC}")
        print(f"  Uptime: {self._format_duration(status['uptime'])}")
        
        print(f"\n{Colors.BOLD}Event Bus{Colors.ENDC}")
        print(f"  Published: {status['event_bus']['published']}")
        print(f"  Processed: {status['event_bus']['processed']}")
        print(f"  Failed: {status['event_bus']['failed']}")
        print(f"  Retries: {status['event_bus']['retries']}")
        
        print(f"\n{Colors.BOLD}Sources{Colors.ENDC}")
        print(f"  Total: {len(status['sources'])}")
        running_sources = sum(1 for s in status['sources'] if s['running'])
        print(f"  Running: {running_sources}")
        
        print(f"\n{Colors.BOLD}Pipelines{Colors.ENDC}")
        print(f"  Total: {status['pipelines']['total_sinks']} sinks")
        
        print()
    
    def _print_sources(self, sources: List[Dict]):
        """打印事件源列表"""
        print(f"\n{Colors.BOLD}Event Sources ({len(sources)}){Colors.ENDC}\n")
        print(f"{'ID':<30} {'Type':<15} {'Enabled':<10} {'Running':<10} {'Errors':<8}")
        print("-" * 80)
        
        for src in sources:
            enabled = f"{Colors.OKGREEN}✓{Colors.ENDC}" if src['enabled'] else f"{Colors.FAIL}✗{Colors.ENDC}"
            running = f"{Colors.OKGREEN}✓{Colors.ENDC}" if src['running'] else f"{Colors.FAIL}✗{Colors.ENDC}"
            
            print(f"{src['id']:<30} {src['type']:<15} {enabled:<10} {running:<10} {src['error_count']:<8}")
        
        print()
    
    def _print_events(self, events: List[Dict], total: int):
        """打印事件列表"""
        print(f"\n{Colors.BOLD}Events (showing {len(events)} of {total}){Colors.ENDC}\n")
        
        for evt in events:
            ts = datetime.fromtimestamp(evt['timestamp']).strftime('%Y-%m-%d %H:%M:%S')
            priority_stars = '★' * (11 - evt['priority']) if evt['priority'] <= 5 else '☆' * (evt['priority'] - 4)
            
            print(f"{Colors.HEADER}[{evt['source']}] {evt['type']}{Colors.ENDC}")
            print(f"  Time: {ts} (priority: {priority_stars})")
            print(f"  Tags: {', '.join(evt['tags'])}")
            
            # 打印关键数据
            summary = self._summarize_data(evt['data'])
            if summary:
                print(f"  Data: {summary}")
            
            print()
        
        print()
    
    def _summarize_data(self, data: Dict, max_len: int = 100) -> str:
        """摘要化事件数据"""
        important = []
        for k, v in list(data.items())[:3]:
            if isinstance(v, (str, int, float, bool)):
                val_str = str(v)
                if len(val_str) > 50:
                    val_str = val_str[:47] + '...'
                important.append(f"{k}={val_str}")
        
        if not important:
            return ""
        
        summary = ", ".join(important)
        if len(summary) > max_len:
            summary = summary[:max_len-3] + "..."
        
        return summary
    
    def _format_duration(self, seconds: float) -> str:
        """格式化时长"""
        units = [
            ('day', 86400),
            ('hour', 3600),
            ('min', 60),
            ('sec', 1)
        ]
        
        parts = []
        for name, unit in units:
            if seconds >= unit:
                count = int(seconds // unit)
                seconds %= unit
                parts.append(f"{count}{name}")
        
        return " ".join(parts) if parts else "0 sec"


async def main():
    parser = argparse.ArgumentParser(
        description='WorldMonitor - External Event Monitoring System',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  %(prog)s start              Start in foreground
  %(prog)s start --daemon     Start in background
  %(prog)s stop               Stop service
  %(prog)s status             Show status
  %(prog)s reload             Reload configuration
  %(prog)s sources            List all sources
  %(prog)s events             Show recent events
  %(prog)s events --source tech_blogs --limit 10
  %(prog)s toggle webhook_receiver
  %(prog)s send-test --type rss.entry --data '{"title": "Test"}'
        """
    )
    
    parser.add_argument('command', 
                       choices=['start', 'stop', 'status', 'reload', 
                               'sources', 'events', 'toggle', 'send-test'],
                       help='Command to execute')
    
    parser.add_argument('--daemon', action='store_true',
                       help='Run as daemon (with start)')
    parser.add_argument('--foreground', action='store_true',
                       help='Run in foreground (default)')
    parser.add_argument('--limit', type=int, default=20,
                       help='Limit number of events (with events)')
    parser.add_argument('--source', help='Filter by source')
    parser.add_argument('--type', help='Filter by event type')
    parser.add_argument('--data', default='{}',
                       help='JSON data for test event')
    
    args = parser.parse_args()
    
    cli = WorldMonitorCLI()
    
    # 配置日志
    import logging
    logging.basicConfig(
        level=logging.WARNING,
        format='%(levelname)s: %(message)s'
    )
    
    try:
        if args.command == 'start':
            return await cli.start(daemon=args.daemon, foreground=args.foreground)
        
        elif args.command == 'stop':
            return await cli.stop()
        
        elif args.command == 'status':
            return await cli.status()
        
        elif args.command == 'reload':
            return await cli.reload()
        
        elif args.command == 'sources':
            return await cli.list_sources()
        
        elif args.command == 'events':
            return await cli.list_events(
                limit=args.limit,
                source=args.source,
                event_type=args.type
            )
        
        elif args.command == 'toggle':
            if not sys.argv[2:]:
                print_error("Source ID required")
                return 1
            return await cli.toggle_source(sys.argv[2])
        
        elif args.command == 'send-test':
            return await cli.send_test_event(
                event_type=args.type or 'test',
                data=args.data
            )
        
    except KeyboardInterrupt:
        print("\nInterrupted")
        return 130
    except Exception as e:
        print_error(f"Error: {e}")
        return 1


if __name__ == '__main__':
    import aiohttp
    exit_code = asyncio.run(main())
    sys.exit(exit_code)
